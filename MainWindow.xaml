<Window x:Class="ClaudeCodeGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClaudeCodeGUI"
        Title="Claude Code 代码助手"
        Icon="img/barcode_6299441_256x256.ico"
        Height="700" Width="1100"
        MinHeight="480" MinWidth="800"
        Background="{DynamicResource ThemeBackground}"
        FontFamily="Consolas, Courier New"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        WindowChrome.WindowChrome="{StaticResource CustomWindowChrome}">

<!-- Styles moved to Themes/AppStyles.xaml -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════ TITLE BAR (draggable, custom chrome) ══════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeSurface2}"
                BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,0,0,1"
                Padding="14,8"
                MouseLeftButtonDown="TitleBar_DragMove">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="img/barcode_6299441.png" Width="26" Height="26"
                           Stretch="Uniform" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Claude Code" Foreground="{DynamicResource ThemeTextPrimary}"
                                   FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"/>
                        <TextBlock x:Name="SubtitleLabel" Text="未启动"
                                   Foreground="{DynamicResource ThemeTextSecondary}" FontSize="10" FontFamily="Segoe UI"/>
                    </StackPanel>
                </StackPanel>

                <!-- ═══ Session Tab Bar ═══ -->
                <ScrollViewer Grid.Column="1" VerticalAlignment="Center"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              Background="Transparent" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <ItemsControl x:Name="SessionTabBar" Focusable="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6"
                                            Padding="12,4,8,4" Margin="2,0"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="TabItem_Click">
                                        <Border.ContextMenu>
                                            <ContextMenu Opened="TabContextMenu_Opened"
                                                         Background="{DynamicResource ThemeSurface3}"
                                                         BorderBrush="{DynamicResource ThemeBorder2}"
                                                         BorderThickness="1">
                                                <MenuItem Header="⏹ 停止"
                                                          Click="TabStopMenuItem_Click"
                                                          Foreground="{DynamicResource ThemeError}"
                                                          Background="{DynamicResource ThemeSurface3}"
                                                          FontFamily="Segoe UI"/>
                                                <MenuItem Header="等待中…"
                                                          IsEnabled="False"
                                                          Visibility="Collapsed"
                                                          Foreground="{DynamicResource ThemeTextMuted}"
                                                          Background="{DynamicResource ThemeSurface3}"
                                                          FontFamily="Segoe UI"/>
                                                <Separator Background="{DynamicResource ThemeBorder2}"/>
                                                <MenuItem Header="🗑 清空对话"
                                                          Click="TabClearMenuItem_Click"
                                                          Foreground="{DynamicResource ThemeTextPrimary}"
                                                          Background="{DynamicResource ThemeSurface3}"
                                                          FontFamily="Segoe UI"/>
                                                <Separator Background="{DynamicResource ThemeBorder2}"/>
                                                <MenuItem Header="关闭标签"
                                                          Click="TabCloseMenuItem_Click"
                                                          Foreground="{DynamicResource ThemeTextPrimary}"
                                                          Background="{DynamicResource ThemeSurface3}"
                                                          FontFamily="Segoe UI"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource ThemeSurface3}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12" FontFamily="Segoe UI"
                                                       Foreground="{DynamicResource ThemeTextPrimary}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="  ×" FontSize="11" FontFamily="Segoe UI"
                                                       Foreground="{DynamicResource ThemeTextMuted}"
                                                       Padding="6,0,0,0"
                                                       MouseLeftButtonDown="TabClose_Click"
                                                       Cursor="Hand"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border x:Name="AddTabButton" CornerRadius="6" Width="24" Height="24"
                                Background="Transparent" Cursor="Hand"
                                MouseLeftButtonDown="AddTab_Click"
                                VerticalAlignment="Center">
                            <TextBlock Text="+" Foreground="{DynamicResource ThemeTextSecondary}"
                                       FontSize="18" FontWeight="Light" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Status pill -->
                <Border Grid.Column="2" Background="{DynamicResource ThemeSurface2}" CornerRadius="9"
                        Padding="8,3" Margin="0,0,10,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="6" Height="6"
                                 Fill="{DynamicResource ThemeSuccess}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="空闲"
                                   Foreground="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                   FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Theme toggle button -->
                <Button x:Name="ThemeToggleBtn" Grid.Column="3"
                        Click="ThemeToggle_Click"
                        Background="Transparent" BorderThickness="0"
                        Width="44" Height="32" Cursor="Hand"
                        ToolTip="切换主题"
                        Margin="0,0,6,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                <TextBlock Text="&#x263E;" Foreground="{DynamicResource ThemeTextSecondary}"
                                           FontSize="14" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource ThemeSurface3}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Window controls -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Minimize -->
                    <Button Click="WinMinimize_Click"
                            Background="Transparent" BorderThickness="0"
                            Width="44" Height="32" Cursor="Hand"
                            ToolTip="最小化">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="&#x2212;" Foreground="{DynamicResource ThemeTextSecondary}"
                                               FontSize="14" FontFamily="Segoe UI"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource ThemeSurface3}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Maximize/Restore -->
                    <Button x:Name="MaximizeButton" Click="WinMaximize_Click"
                            Background="Transparent" BorderThickness="0"
                            Width="44" Height="32" Cursor="Hand"
                            ToolTip="最大化">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                    <TextBlock x:Name="MaximizeIcon" Text="&#x25A1;" Foreground="{DynamicResource ThemeTextSecondary}"
                                               FontSize="12" FontFamily="Segoe UI"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource ThemeSurface3}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Close -->
                    <Button Click="WinClose_Click"
                            Background="Transparent" BorderThickness="0"
                            Width="44" Height="32" Cursor="Hand"
                            ToolTip="关闭">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="&#x2715;" Foreground="{DynamicResource ThemeTextSecondary}"
                                               FontSize="12" FontFamily="Segoe UI"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource ThemeWindowBtnCloseHover}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ThemeError}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════ TOOLBAR (Phase 3: collapsed; buttons moved to tabs/thinking bar) ══════════════ -->
        <Border Grid.Row="1" Background="{DynamicResource ThemeSurface2}"
                BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,0,0,1"
                Padding="12,7" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="目录:" Foreground="{DynamicResource ThemeTextSecondary}"
                           FontSize="11" FontFamily="Segoe UI"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="WorkingDirBox" Grid.Column="1"
                         Style="{StaticResource PathBox}"
                         Text="C:\Users\PLAUD"
                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button x:Name="BrowseButton" Grid.Column="2"
                        Content="浏览"
                        Background="{DynamicResource ThemeSurface3}" Foreground="{DynamicResource ThemeTextPrimary}"
                        Style="{StaticResource FlatButton}"
                        Padding="12,5" FontSize="12"
                        Click="BrowseDir_Click" Margin="0,0,6,0"/>
                <Button x:Name="StopButton" Grid.Column="3"
                        Content="停止"
                        Background="{DynamicResource ThemeWindowBtnCloseHover}" Foreground="{DynamicResource ThemeError}"
                        Style="{StaticResource FlatButton}"
                        Padding="12,5" FontSize="12"
                        IsEnabled="False"
                        Click="StopSession_Click" Margin="0,0,6,0"/>
                <Button Grid.Column="4"
                        Content="清空"
                        Background="{DynamicResource ThemeSurface3}" Foreground="{DynamicResource ThemeTextSecondary}"
                        Style="{StaticResource FlatButton}"
                        Padding="10,5" FontSize="11"
                        Click="ClearOutput_Click" Margin="0,0,6,0"/>
                <Button x:Name="SaveSkillBtn" Grid.Column="5"
                        Content="&#x2728; 保存为技能"
                        Background="{DynamicResource ThemeSkillChipBg}" Foreground="{DynamicResource ThemeAccent}"
                        Style="{StaticResource FlatButton}"
                        Padding="10,5" FontSize="11"
                        FontFamily="Segoe UI" FontWeight="SemiBold"
                        IsEnabled="False"
                        Click="SaveAsSkill_Click"
                        ToolTip="让 Claude 将对话总结为可复用的技能"
                        Margin="0,0,6,0"/>
                <Button Grid.Column="6"
                        Content="新任务"
                        Background="{DynamicResource ThemeSuccessBg}" Foreground="{DynamicResource ThemeSuccess}"
                        Style="{StaticResource FlatButton}"
                        Padding="10,5" FontSize="11"
                        FontFamily="Segoe UI"
                        Click="NewTask_Click"
                        ToolTip="打开新 Claude Code 窗口"/>
            </Grid>
        </Border>

        <!-- ══════════════ MAIN: SIDEBAR + CHAT ══════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="170" MaxWidth="380"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ SIDEBAR (SKILLS + PROJECTS) ═══ -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeSurface1}"
                    BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ── Tab bar: [技能] [项目] + contextual actions ── -->
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,0,0,1"
                            Padding="14,11,10,11">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Skills tab button -->
                            <Border x:Name="SidebarSkillsTab" Grid.Column="0"
                                    CornerRadius="6" Padding="10,5" Margin="0,0,4,0"
                                    Background="{DynamicResource ThemeSurface3}"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="SidebarTabSkills_Click">
                                <TextBlock Text="技能"
                                           FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ThemeAccent}"/>
                            </Border>

                            <!-- Projects tab button -->
                            <Border x:Name="SidebarProjectsTab" Grid.Column="1"
                                    CornerRadius="6" Padding="10,5"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="SidebarTabProjects_Click">
                                <TextBlock Text="项目"
                                           FontSize="12" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource ThemeTextMuted}"/>
                            </Border>

                            <!-- Skills count badge -->
                            <TextBlock x:Name="SkillsCountLabel" Grid.Column="0"
                                       Foreground="{DynamicResource ThemeTextMuted}" FontSize="11"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"
                                       Margin="6,0,0,0" Visibility="Collapsed"/>

                            <!-- Spacer -->
                            <Border Grid.Column="2"/>

                            <!-- Action buttons (contextual) -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                        x:Name="SidebarActions">
                                <!-- #region Skills actions -->
                                <Button x:Name="SkillAddBtn"
                                        Style="{StaticResource SidebarIconBtn}"
                                        ToolTip="新建技能 (.md 文件)"
                                        Click="SkillNewSkill_Click">
                                    <TextBlock Text="+" Foreground="{DynamicResource ThemeAccent}" FontSize="17"
                                               FontWeight="Light" FontFamily="Segoe UI"
                                               Margin="0,-1,0,0"/>
                                </Button>
                                <Button x:Name="SkillFolderBtn"
                                        Style="{StaticResource SidebarIconBtn}"
                                        ToolTip="新建分组文件夹"
                                        Click="SkillNewFolder_Click">
                                    <TextBlock Text="&#x1F4C2;" FontSize="12"/>
                                </Button>
                                <Button x:Name="SkillGenerateBtn"
                                        Style="{StaticResource SidebarIconBtn}"
                                        ToolTip="保存对话为技能 (AI 总结)"
                                        Click="SkillGenerate_Click">
                                    <TextBlock Text="&#x2728;" FontSize="11"/>
                                </Button>
                                <Button x:Name="SkillRefreshBtn"
                                        Style="{StaticResource SidebarIconBtn}"
                                        ToolTip="刷新"
                                        Click="SkillRefresh_Click">
                                    <TextBlock Text="&#x21BB;" FontSize="12" Foreground="{DynamicResource ThemeTextMuted}"/>
                                </Button>
                                <!-- #endregion -->
                                <!-- #region Project actions (hidden by default) -->
                                <Button x:Name="ProjectAddBtn"
                                        Style="{StaticResource SidebarIconBtn}"
                                        Visibility="Collapsed"
                                        ToolTip="添加项目"
                                        Click="AddProject_Click">
                                    <TextBlock Text="+" Foreground="{DynamicResource ThemeAccent}" FontSize="17"
                                               FontWeight="Light" FontFamily="Segoe UI"
                                               Margin="0,-1,0,0"/>
                                </Button>
                                <!-- #endregion -->
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Content area (switched by active tab) ── -->
                    <Grid Grid.Row="1">
                        <!-- ═══ Skills panel ═══ -->
                        <Grid x:Name="SkillsPanel">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Search box -->
                            <Border Grid.Row="0" Padding="8,6,8,6"
                                    BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,0,0,1">
                                <Border Background="{DynamicResource ThemeSurface2}" CornerRadius="8"
                                        BorderBrush="{DynamicResource ThemeBorder2}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="&#x1F50D;"
                                                   FontSize="11" Margin="8,0,4,0"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource ThemeTextMuted}"/>
                                        <TextBox x:Name="SkillSearchBox" Grid.Column="1"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource ThemeTextPrimary}"
                                                 BorderThickness="0"
                                                 CaretBrush="{DynamicResource ThemeAccent}"
                                                 FontSize="12" FontFamily="Segoe UI"
                                                 Padding="0,6,8,6"
                                                 TextChanged="SkillSearch_TextChanged"/>
                                    </Grid>
                                </Border>
                            </Border>

                            <!-- Skill list (ItemsControl) -->
                            <ScrollViewer Grid.Row="1"
                                          Style="{StaticResource SidebarScrollViewer}"
                                          Background="Transparent"
                                          Padding="8,6,8,4">
                                <ItemsControl x:Name="SkillsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent"
                                                    CornerRadius="8"
                                                    Margin="0,2,0,2"
                                                    Padding="10,8,10,8"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="SkillCard_Click">
                                                <Border.ContextMenu>
                                                    <ContextMenu Background="{DynamicResource ThemeSurface3}"
                                                                 BorderBrush="{DynamicResource ThemeBorder2}" BorderThickness="1"
                                                                 Opened="SkillContextMenu_Opened">
                                                        <MenuItem Header="&#x25B6;  插入命令"
                                                                  Click="SkillUse_Click"
                                                                  Foreground="{DynamicResource ThemeAccent}" Background="{DynamicResource ThemeSurface3}"
                                                                  FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                                        <Separator Background="{DynamicResource ThemeBorder2}"/>
                                                        <MenuItem Header="新建技能"
                                                                  Click="SkillNewSkill_Click"
                                                                  Foreground="{DynamicResource ThemeSuccess}" Background="{DynamicResource ThemeSurface3}"
                                                                  FontFamily="Segoe UI"/>
                                                        <MenuItem Header="重命名 / 编辑描述"
                                                                  Click="SkillRename_Click"
                                                                  Foreground="{DynamicResource ThemeTextPrimary}" Background="{DynamicResource ThemeSurface3}"
                                                                  FontFamily="Segoe UI"/>
                                                        <Separator Background="{DynamicResource ThemeSurface4}"/>
                                                        <MenuItem Header="删除"
                                                                  Click="SkillDelete_Click"
                                                                  Foreground="{DynamicResource ThemeError}" Background="{DynamicResource ThemeSurface3}"
                                                                  FontFamily="Segoe UI"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                            <Border Background="Transparent" CornerRadius="4" Padding="0">
                                                                <TextBlock Text="{Binding CmdDisplay}"
                                                                           Foreground="{DynamicResource ThemeAccent}"
                                                                           FontSize="11"
                                                                           FontFamily="Consolas, Courier New"
                                                                           FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding GroupTag}"
                                                                       Foreground="{DynamicResource ThemeTextMuted}"
                                                                       FontSize="10"
                                                                       FontFamily="Segoe UI"
                                                                       VerticalAlignment="Center"
                                                                       Margin="6,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding DescSnippet}"
                                                                   Foreground="{DynamicResource ThemeTextSecondary}"
                                                                   FontSize="10"
                                                                   FontFamily="Segoe UI"
                                                                   TextWrapping="Wrap"
                                                                   MaxWidth="160"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1"
                                                            Background="{DynamicResource ThemeSkillChipBg}" CornerRadius="6"
                                                            Width="26" Height="26"
                                                            VerticalAlignment="Center"
                                                            Cursor="Hand"
                                                            MouseLeftButtonDown="SkillCardInsert_Click"
                                                            ToolTip="插入命令">
                                                        <TextBlock Text="&#x25B6;"
                                                                   Foreground="{DynamicResource ThemeAccent}"
                                                                   FontSize="9"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Bottom preview -->
                            <Border Grid.Row="2" Background="{DynamicResource ThemeBackground}"
                                    BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,1,0,0"
                                    Padding="12,10">
                                <StackPanel>
                                    <TextBlock x:Name="SkillPreviewCmd"
                                               Text="未选中技能"
                                               Foreground="{DynamicResource ThemeTextSecondary}" FontSize="12"
                                               FontFamily="Consolas, Courier New"
                                               FontWeight="Bold"/>
                                    <TextBlock x:Name="SkillPreviewDesc"
                                               Text=""
                                               Foreground="{DynamicResource ThemeTextMuted}" FontSize="10"
                                               FontFamily="Segoe UI"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"
                                               MaxHeight="44"/>
                                    <Button x:Name="SkillInsertBtn"
                                            Content="&#x25B6;  插入命令"
                                            Background="{DynamicResource ThemeSkillChipBg}" Foreground="{DynamicResource ThemeAccent}"
                                            Style="{StaticResource FlatButton}"
                                            Padding="0,7" FontSize="12"
                                            FontFamily="Segoe UI" FontWeight="SemiBold"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Click="SkillUse_Click"
                                            Margin="0,8,0,0"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ═══ Projects panel ═══ -->
                        <Grid x:Name="ProjectsPanel" Visibility="Collapsed">
                            <local:ProjectSidebar x:Name="ProjectSidebarCtrl"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Divider -->
            <Border Grid.Column="1" Background="{DynamicResource ThemeSurface3}"/>

            <!-- ═══ CHAT ═══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="OutputScroller" Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource ThemeBackground}" Padding="0">
                    <StackPanel x:Name="ChatPanel" Margin="0,8,0,8"/>
                </ScrollViewer>

                <!-- Progress strip with scrolling activity log -->
                <Border x:Name="ThinkingBar" Grid.Row="1"
                        Background="{DynamicResource ThemeBackground}"
                        BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,2,0,0"
                        Visibility="Collapsed" MinHeight="60">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 主文本与活动日志同在中间 * 列，避免整行活动区在计时器下方留下大块空白 -->
                        <Grid Grid.Row="0" Margin="14,8,14,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*" MinWidth="120"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                    Background="{DynamicResource ThemeSkillChipBg}" Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBlock x:Name="SpinnerText" Text="⠋"
                                           Foreground="{DynamicResource ThemeAccent}" FontSize="13"
                                           FontFamily="Consolas"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Column="1" x:Name="ThinkingLabel"
                                       Text="发送中"
                                       Foreground="{DynamicResource ThemeAccent}" FontSize="12"
                                       FontFamily="Segoe UI" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <Grid Grid.Column="2" Margin="10,0,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0" x:Name="LiveOutputLabel"
                                         Text=""
                                         IsReadOnly="True"
                                         IsTabStop="False"
                                         Focusable="False"
                                         Cursor="Arrow"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="0"
                                         Margin="0"
                                         HorizontalAlignment="Stretch"
                                         Foreground="{DynamicResource ThemeTextSecondary}"
                                         FontSize="11"
                                         FontFamily="Consolas, Courier New"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="False"
                                         AcceptsTab="False"
                                         VerticalContentAlignment="Top"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Hidden"/>
                                <Border x:Name="ActivityLogHost" Grid.Row="1" Padding="0,2,0,2" Background="Transparent"
                                        MaxHeight="120" Margin="0,2,0,0" Visibility="Collapsed">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="ThinkingBarTasksList" ItemsSource="{Binding Tasks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:TodoItem}">
                                                    <Border Background="Transparent" CornerRadius="6" Margin="0,1,0,1" Padding="4,3,4,3">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                     Fill="{Binding Status, Converter={StaticResource TaskStatusToColorConverter}}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Content}"
                                                                       Foreground="{DynamicResource ThemeTextSecondary}"
                                                                       FontSize="11" FontFamily="Consolas, Courier New" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding ActiveForm}"
                                                                       Foreground="{DynamicResource ThemeTextMuted}"
                                                                       FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="8,0,0,0"
                                                                       Visibility="{Binding ActiveForm, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>

                            <TextBlock Grid.Column="3" x:Name="ElapsedLabel" Text="0s"
                                       Foreground="{DynamicResource ThemeAccent}" FontSize="13"
                                       FontFamily="Consolas" FontWeight="Bold"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="4" x:Name="ThinkingStopBtn"
                                    Width="26" Height="26" CornerRadius="13"
                                    Background="#3A1A1A" Cursor="Hand"
                                    VerticalAlignment="Center" Margin="6,0,0,0"
                                    MouseLeftButtonDown="StopSession_Click"
                                    ToolTip="停止">
                                <TextBlock Text="⏹" FontSize="11"
                                           Foreground="#FF4444"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Progress bar track -->
                        <Border Grid.Row="1" Height="2" Background="{DynamicResource ThemeSkillChipBg}" Margin="0,0,0,0">
                            <Border x:Name="ProgressBarFill"
                                    HorizontalAlignment="Left"
                                    Width="0" Height="2"
                                    Background="#0A84FF"
                                    CornerRadius="1"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Input area -->
                <Border Grid.Row="2" Background="{DynamicResource ThemeSurface2}"
                        BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Image preview -->
                            <RowDefinition Height="Auto"/>  <!-- Text input -->
                            <RowDefinition Height="Auto"/>  <!-- Bottom toolbar -->
                        </Grid.RowDefinitions>

                        <!-- Image preview strip (hidden when no image) -->
                        <Border x:Name="ImagePreviewBar" Grid.Row="0"
                                Visibility="Collapsed"
                                Background="{DynamicResource ThemeBackground}"
                                BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,0,0,1"
                                Padding="10,6" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image x:Name="ImagePreviewThumb"
                                       Grid.Column="0"
                                       Width="40" Height="40"
                                       Stretch="UniformToFill"
                                       Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="ImagePreviewName"
                                               Foreground="{DynamicResource ThemeTextPrimary}" FontSize="12"
                                               FontFamily="Segoe UI"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="ImagePreviewSize"
                                               Foreground="{DynamicResource ThemeTextMuted}" FontSize="10"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="&#x2715;"
                                        Background="Transparent" Foreground="{DynamicResource ThemeTextMuted}"
                                        Style="{StaticResource FlatButton}"
                                        Padding="6,4" FontSize="13"
                                        Click="ClearImage_Click"
                                        ToolTip="移除图片"/>
                            </Grid>
                        </Border>

                        <!-- Text input -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <TextBox x:Name="InputBox"
                                     Style="{StaticResource InputStyle}"
                                     MinHeight="36" MaxHeight="140"
                                     PreviewKeyDown="InputBox_PreviewKeyDown"
                                     TextChanged="InputBox_TextChanged"
                                     GotFocus="InputBox_GotFocus"
                                     LostFocus="InputBox_LostFocus"/>
                            <TextBlock x:Name="InputPlaceholder"
                                       Text="输入消息... (Enter = 发送, Ctrl+Enter / Shift+Enter = 换行)"
                                       Foreground="{DynamicResource ThemeTextMuted}" FontSize="13"
                                       FontFamily="Consolas, Courier New"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Top"
                                       Margin="14,11,12,0"/>
                        </Grid>

                        <!-- Bottom toolbar -->
                        <Border Grid.Row="2" Background="{DynamicResource ThemeSurface3}"
                                BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,1,0,0"
                                Padding="10,6" Margin="-14,-10,-14,-10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>   <!-- Model selection -->
                                    <ColumnDefinition Width="Auto"/>   <!-- Build/Plan toggle -->
                                    <ColumnDefinition Width="Auto"/>   <!-- Permission dropdown -->
                                    <ColumnDefinition Width="*"/>      <!-- Spacer -->
                                    <ColumnDefinition Width="Auto"/>   <!-- Tokens indicator -->
                                    <ColumnDefinition Width="Auto"/>   <!-- Save as Skill -->
                                    <ColumnDefinition Width="Auto"/>   <!-- Clear chat -->
                                    <ColumnDefinition Width="Auto"/>   <!-- Send/Stop button -->
                                </Grid.ColumnDefinitions>

                                <!-- Model selection -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                    <ComboBox x:Name="ModelComboBox"
                                              Width="140" Height="28"
                                              VerticalContentAlignment="Center"
                                              FontSize="12" FontFamily="Segoe UI"
                                              Background="Transparent"
                                              BorderBrush="{DynamicResource ThemeBorder1}"
                                              ToolTip="选择模型"/>
                                    <Button x:Name="RefreshModelsBtn"
                                            Width="24" Height="28"
                                            Margin="4,0,0,0"
                                            Background="Transparent"
                                            Style="{StaticResource FlatButton}"
                                            Content="&#x21BB;"
                                            FontSize="12"
                                            ToolTip="刷新模型列表"
                                            Click="RefreshModels_Click"/>
                                </StackPanel>

                                <!-- Build/Plan toggle -->
                                <Button x:Name="ModeToggleButton"
                                        Grid.Column="1"
                                        Content="构建"
                                        Width="60" Height="26"
                                        Background="{DynamicResource ThemeAccent}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Margin="0,0,8,0"
                                        Click="ToggleMode_Click"
                                        ToolTip="点击在构建和计划模式间切换">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Permission dropdown -->
                                <Button Grid.Column="2" x:Name="PermissionBtn"
                                        Content="监督模式"
                                        Width="90" Height="28"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ThemeTextPrimary}"
                                        BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="1"
                                        Click="OpenPermissionPopup_Click"
                                        ToolTip="点击切换权限模式：监督模式/自动接受编辑/完全访问"/>

                                <!-- Tokens circular indicator -->
                                <Border Grid.Column="4" x:Name="TokenIndicatorBorder"
                                        Width="28" Height="28"
                                        Margin="0,0,8,0"
                                        Background="{DynamicResource ThemeBackground}"
                                        BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="1"
                                        CornerRadius="14"
                                        ToolTip="Token 使用量">
                                    <Grid>
                                        <!-- Background circle -->
                                        <Ellipse Width="20" Height="20"
                                                 Stroke="{DynamicResource ThemeBorder1}" StrokeThickness="2"
                                                 Fill="Transparent"/>
                                        <!-- Progress arc (updated via code) -->
                                        <Path x:Name="TokenProgressArc"
                                              Stroke="{DynamicResource ThemeAccent}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Fill="Transparent"
                                              Data="M 14,4 A 10,10 0 0 1 14,24"/>
                                        <!-- Percentage text -->
                                        <TextBlock x:Name="TokenPercentText"
                                                   Text="0%"
                                                   FontSize="8" FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeTextPrimary}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Save as Skill button -->
                                <Button Grid.Column="5" x:Name="BottomSaveSkillBtn"
                                        Width="28" Height="26"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ThemeAccent}"
                                        BorderBrush="{DynamicResource ThemeBorder1}"
                                        BorderThickness="1" Margin="0,0,4,0"
                                        Style="{StaticResource FlatButton}"
                                        Content="&#x2728;"
                                        FontSize="11"
                                        ToolTip="保存对话为技能"
                                        Click="SaveAsSkill_Click"/>

                                <!-- Clear chat button -->
                                <Button Grid.Column="6"
                                        Width="28" Height="26"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ThemeTextMuted}"
                                        BorderBrush="{DynamicResource ThemeBorder1}"
                                        BorderThickness="1" Margin="0,0,4,0"
                                        Style="{StaticResource FlatButton}"
                                        Content="&#x1F5D1;"
                                        FontSize="11"
                                        ToolTip="清空对话"
                                        Click="ClearOutput_Click"/>

                                <!-- Send/Stop button -->
                                <Button Grid.Column="7" x:Name="SendButton"
                                        Content="&#x25B6;"
                                        Width="44" Height="28"
                                        Background="#0A84FF" Foreground="White"
                                        BorderThickness="0"
                                        Style="{StaticResource FlatButton}"
                                        FontSize="14"
                                        IsEnabled="False"
                                        Click="SendMessage_Click"
                                        ToolTip="发送消息"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════ STATUS BAR ══════════════ -->
        <Border Grid.Row="3" Background="#141416"
                BorderBrush="{DynamicResource ThemeBorder1}" BorderThickness="0,1,0,0"
                Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBar"
                           Text="点击「浏览」选择工作目录。"
                           Foreground="{DynamicResource ThemeTextMuted}" FontSize="11"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <TextBlock x:Name="TurnCounter" Grid.Column="1"
                           Text="" Foreground="{DynamicResource ThemeTextMuted}" FontSize="11"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
