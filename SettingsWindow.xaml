<Window x:Class="ClaudeCodeGUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="600"
        Height="450"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackground}"
        Foreground="{DynamicResource ThemeTextPrimary}"
        BorderBrush="{DynamicResource ThemeBorder1}"
        BorderThickness="1">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left navigation sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource ThemeSurface2}"
                BorderBrush="{DynamicResource ThemeBorder1}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="0">
                <TextBlock Text="Settings"
                           Foreground="{DynamicResource ThemeTextPrimary}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="12,16,12,12" />
                <ListBox x:Name="NavList"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectedIndex="0"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBoxItem>
                        <TextBlock Text="General"
                                   Foreground="{DynamicResource ThemeTextSecondary}"
                                   FontSize="13"
                                   Padding="12,6" />
                    </ListBoxItem>
                    <ListBoxItem>
                        <TextBlock Text="Theme"
                                   Foreground="{DynamicResource ThemeTextSecondary}"
                                   FontSize="13"
                                   Padding="12,6" />
                    </ListBoxItem>
                    <ListBoxItem>
                        <TextBlock Text="Appearance"
                                   Foreground="{DynamicResource ThemeTextSecondary}"
                                   FontSize="13"
                                   Padding="12,6" />
                    </ListBoxItem>
                    <ListBoxItem>
                        <TextBlock Text="Editor"
                                   Foreground="{DynamicResource ThemeTextSecondary}"
                                   FontSize="13"
                                   Padding="12,6" />
                    </ListBoxItem>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Right content area -->
        <Border Grid.Column="1"
                Background="{DynamicResource ThemeBackground}"
                Padding="16">
            <ContentControl x:Name="ContentArea" />
        </Border>
    </Grid>
</Window>
