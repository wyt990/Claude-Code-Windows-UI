<Window x:Class="ClaudeCodeGUI.ApprovalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工具调用审批"
        Width="480" Height="380"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        Background="{DynamicResource ThemeApprovalBg}"
        Foreground="{DynamicResource ThemeTextPrimary}"
        FontFamily="Segoe UI"
        Loaded="ApprovalDialog_Loaded">
    <Border BorderBrush="{DynamicResource ThemeApprovalBorder}"
            BorderThickness="1"
            CornerRadius="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="&#x26A1;" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="工具调用需要审批"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeTextPrimary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Tool info -->
            <Border Grid.Row="1"
                    Background="{DynamicResource ThemeSurface2}"
                    CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="工具:"
                               Foreground="{DynamicResource ThemeTextMuted}"
                               FontSize="12" Margin="0,0,12,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               x:Name="ToolNameText"
                               Foreground="{DynamicResource ThemeAccent}"
                               FontSize="13" FontWeight="SemiBold"
                               FontFamily="Consolas, Courier New"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="参数:"
                               Foreground="{DynamicResource ThemeTextMuted}"
                               FontSize="12" Margin="0,0,12,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               x:Name="ToolDescriptionText"
                               Foreground="{DynamicResource ThemeTextSecondary}"
                               FontSize="12"
                               FontFamily="Consolas, Courier New"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <!-- JSON params label -->
            <TextBlock Grid.Row="2"
                       Text="参数详情 (JSON)"
                       Foreground="{DynamicResource ThemeTextSecondary}"
                       FontSize="11" Margin="0,0,0,4"/>

            <!-- JSON params display -->
            <Border Grid.Row="3"
                    Background="{DynamicResource ThemeSurface2}"
                    BorderBrush="{DynamicResource ThemeBorder1}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="10,8" Margin="0,0,0,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="JsonTextBox"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="{DynamicResource ThemeTextPrimary}"
                             BorderThickness="0"
                             FontFamily="Consolas, Courier New"
                             FontSize="12"
                             TextWrapping="Wrap"
                             Padding="2"/>
                </ScrollViewer>
            </Border>

            <!-- Remember checkbox -->
            <CheckBox Grid.Row="4"
                      x:Name="AllowAlwaysCheckbox"
                      Content="本次会话始终允许此工具"
                      Foreground="{DynamicResource ThemeTextSecondary}"
                      FontSize="12"
                      Margin="0,0,0,12"
                      Checked="AllowAlways_Checked"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="DenyBtn"
                        Content="拒绝"
                        Width="90" Height="32"
                        Background="{DynamicResource ThemeSurface3}"
                        Foreground="{DynamicResource ThemeError}"
                        BorderBrush="{DynamicResource ThemeBorder1}"
                        BorderThickness="1"
                        Click="DenyBtn_Click"
                        Cursor="Hand"
                        FontSize="13"/>
                <Border Width="8"/>
                <Button x:Name="AllowBtn"
                        Content="批准"
                        Width="90" Height="32"
                        Background="{DynamicResource ThemeAccent}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="AllowBtn_Click"
                        Cursor="Hand"
                        FontSize="13" FontWeight="SemiBold"/>
                <Border Width="8"/>
                <Button x:Name="AllowAllBtn"
                        Content="全部允许"
                        Width="90" Height="32"
                        Background="{DynamicResource ThemeSurface3}"
                        Foreground="{DynamicResource ThemeTextPrimary}"
                        BorderBrush="{DynamicResource ThemeBorder1}"
                        BorderThickness="1"
                        Click="AllowAllBtn_Click"
                        Cursor="Hand"
                        FontSize="13"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
