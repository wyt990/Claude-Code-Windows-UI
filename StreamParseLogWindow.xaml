<Window x:Class="ClaudeCodeGUI.StreamParseLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="流解析诊断日志"
        Width="720" Height="520"
        MinWidth="480" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBackground}"
        Foreground="{DynamicResource ThemeTextPrimary}"
        FontFamily="Segoe UI">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="stdout 单行解析或事件分发时发生异常。以下为完整诊断信息（含待解析的原始行）。"
                   Foreground="{DynamicResource ThemeTextSecondary}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1"
                Background="{DynamicResource ThemeSurface2}"
                BorderBrush="{DynamicResource ThemeBorder1}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="DetailBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource ThemeTextPrimary}"
                         FontFamily="Consolas, Courier New"
                         FontSize="12"
                         VerticalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="复制全部"
                    Padding="14,6"
                    MinWidth="100"
                    Click="Copy_Click"
                    Cursor="Hand"
                    Background="{DynamicResource ThemeSurface3}"
                    Foreground="{DynamicResource ThemeAccent}"
                    BorderBrush="{DynamicResource ThemeBorder1}"
                    BorderThickness="1"/>
            <Border Width="10"/>
            <Button Content="关闭"
                    Padding="14,6"
                    MinWidth="88"
                    Click="Close_Click"
                    Cursor="Hand"
                    Background="{DynamicResource ThemeAccent}"
                    Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
