<UserControl x:Class="ClaudeCodeGUI.ProjectSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClaudeCodeGUI">
    <Grid Background="Transparent">
        <TreeView x:Name="ProjectTree"
                  ItemsSource="{Binding}"
                  Background="Transparent"
                  BorderThickness="0"
                  FontFamily="Segoe UI"
                  FontSize="12"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseDoubleClick="ProjectTree_MouseDoubleClick">
            <TreeView.Resources>
                <!-- 项目 → 会话 层级模板 -->
                <HierarchicalDataTemplate DataType="{x:Type local:ProjectItem}"
                                          ItemsSource="{Binding Sessions}">
                    <StackPanel Orientation="Horizontal" Margin="2,3">
                        <StackPanel.ContextMenu>
                            <ContextMenu Background="{DynamicResource ThemeSurface3}"
                                         BorderBrush="{DynamicResource ThemeBorder2}" BorderThickness="1">
                                <MenuItem Header="添加会话"
                                          Click="AddSession_Click"
                                          Foreground="{DynamicResource ThemeAccent}"
                                          Background="{DynamicResource ThemeSurface3}"
                                          FontFamily="Segoe UI"/>
                                <MenuItem Header="重命名项目"
                                          Click="RenameProject_Click"
                                          Foreground="{DynamicResource ThemeTextPrimary}"
                                          Background="{DynamicResource ThemeSurface3}"
                                          FontFamily="Segoe UI"/>
                                <Separator Background="{DynamicResource ThemeBorder2}"/>
                                <MenuItem Header="删除项目"
                                          Click="DeleteProject_Click"
                                          Foreground="{DynamicResource ThemeError}"
                                          Background="{DynamicResource ThemeSurface3}"
                                          FontFamily="Segoe UI"/>
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                        <TextBlock Text="&#x1F4C1;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{DynamicResource ThemeTextPrimary}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <HierarchicalDataTemplate.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:SessionItem}">
                            <StackPanel Orientation="Horizontal" Margin="2,3">
                                <StackPanel.ContextMenu>
                                    <ContextMenu Background="{DynamicResource ThemeSurface3}"
                                                 BorderBrush="{DynamicResource ThemeBorder2}" BorderThickness="1">
                                        <MenuItem Header="&#x25B6; 在新标签中打开"
                                                  Click="OpenSession_Click"
                                                  Foreground="{DynamicResource ThemeAccent}"
                                                  Background="{DynamicResource ThemeSurface3}"
                                                  FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                        <Separator Background="{DynamicResource ThemeBorder2}"/>
                                        <MenuItem Header="重命名"
                                                  Click="RenameSession_Click"
                                                  Foreground="{DynamicResource ThemeTextPrimary}"
                                                  Background="{DynamicResource ThemeSurface3}"
                                                  FontFamily="Segoe UI"/>
                                        <Separator Background="{DynamicResource ThemeBorder2}"/>
                                        <MenuItem Header="删除"
                                                  Click="DeleteSession_Click"
                                                  Foreground="{DynamicResource ThemeError}"
                                                  Background="{DynamicResource ThemeSurface3}"
                                                  FontFamily="Segoe UI"/>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Text="&#x1F4AC;" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource ThemeTextSecondary}"
                                           FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:MM/dd}}"
                                           Foreground="{DynamicResource ThemeTextMuted}"
                                           FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </HierarchicalDataTemplate.ItemTemplate>
                </HierarchicalDataTemplate>

                <!-- TreeViewItem 样式 -->
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="True"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="8,3"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ThemeSurface3}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ThemeSkillChipBg}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.Resources>
        </TreeView>
    </Grid>
</UserControl>
