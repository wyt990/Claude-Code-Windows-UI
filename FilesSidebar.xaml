<UserControl x:Class="ClaudeCodeGUI.FilesSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ClaudeCodeGUI">
    <Grid Background="Transparent">
        <TreeView x:Name="FileTree"
                  Background="Transparent"
                  BorderThickness="0"
                  MouseDoubleClick="FileTree_MouseDoubleClick"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <TreeView.Resources>
                <SolidColorBrush x:Key="TreeViewItem.Disabled.Static.Foreground" Color="Transparent" />
                <SolidColorBrush x:Key="TreeViewItem.Disabled.Static.Glyph" Color="Transparent" />

                <Style TargetType="TreeViewItem">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="4,2" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ThemeSurface3}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ThemeSurface4}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <HierarchicalDataTemplate DataType="{x:Type local:FileTreeItem}"
                                          ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding Icon}" FontSize="13" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{DynamicResource ThemeTextPrimary}"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.Resources>
        </TreeView>
    </Grid>
</UserControl>
